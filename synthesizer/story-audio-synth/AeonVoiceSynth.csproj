<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="AeonVoice" Version="0.1.7" />
    <PackageReference Include="AeonVoice.Native" Version="0.1.7" />
  </ItemGroup>

  <ItemGroup>
    <AeonVoiceNativeLibs Include="$(NuGetPackageRoot)aeonvoice.native/0.1.7/linux-arm64/native/*.so*" />
  </ItemGroup>

  <Target Name="CopyAeonVoiceNativeLibs" AfterTargets="Build">
    <Copy SourceFiles="@(AeonVoiceNativeLibs)" DestinationFolder="$(OutDir)" SkipUnchangedFiles="true" />
  </Target>

</Project>
